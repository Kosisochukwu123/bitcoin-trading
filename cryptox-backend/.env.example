# ─────────────────────────────────────────────
#  CryptoX Backend — Environment Variables
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# JWT Secrets  (change these before deploying!)
JWT_SECRET=cryptox_jwt_secret_change_me_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=cryptox_refresh_secret_change_me_too
JWT_REFRESH_EXPIRES_IN=30d

# CORS — frontend origin
CLIENT_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# App Config
DEMO_STARTING_BALANCE=10000
PRICE_TICK_INTERVAL_MS=3000
TRADING_FEE_PERCENT=0.001
